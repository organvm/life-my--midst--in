{
  "name": "in-midst-my-life",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.30.2",
  "description": "Interactive CV/resume system with mask-based identity filtering and narrative generation",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/4444J99/life-my--midst--in.git"
  },
  "homepage": "https://github.com/4444J99/life-my--midst--in#readme",
  "bugs": {
    "url": "https://github.com/4444J99/life-my--midst--in/issues"
  },
  "keywords": [
    "cv",
    "resume",
    "identity",
    "masks",
    "portfolio",
    "verifiable-credentials"
  ],
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:coverage": "COVERAGE=true turbo run test",
    "integration": "turbo run integration",
    "e2e": "turbo run e2e",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "20.4.1",
    "@commitlint/config-conventional": "20.4.1",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@lhci/cli": "^0.14.0",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^16.5.0",
    "husky": "9.1.7",
    "lint-staged": "16.2.7",
    "prettier": "^3.8.3",
    "turbo": "^2.9.16",
    "typescript": "^5.9.3",
    "vite": "^7.3.5",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "fastify": "^5.8.5"
  },
  "pnpm": {
    "overrides": {
      "lodash-es": ">=4.17.23",
      "uuid": ">=11.1.0",
      "qs": ">=6.15.2",
      "cookie": ">=0.7.0",
      "tmp": ">=0.2.4",
      "ws": ">=8.20.1",
      "protobufjs": ">=8.2.0",
      "minimatch": ">=3.1.2",
      "path-to-regexp": ">=0.1.10",
      "yaml": ">=2.2.2",
      "postcss": ">=8.4.31"
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "prettier": {
    "singleQuote": true,
    "trailingComma": "all",
    "semi": true,
    "printWidth": 100
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ],
    "rules": {
      "header-max-length": [
        2,
        "always",
        72
      ],
      "type-enum": [
        2,
        "always",
        [
          "feat",
          "fix",
          "docs",
          "style",
          "refactor",
          "perf",
          "test",
          "build",
          "ci",
          "chore",
          "revert"
        ]
      ],
      "scope-enum": [
        1,
        "always",
        [
          "api",
          "web",
          "orchestrator",
          "schema",
          "core",
          "content-model",
          "design-system",
          "infra",
          "ci",
          "deps"
        ]
      ]
    }
  }
}
