{
  "name": "@in-midst-my-life/orchestrator",
  "version": "0.1.0",
  "private": true,
  "description": "Node.js worker service for task queue processing and agent orchestration",
  "license": "MIT",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "COVERAGE=true vitest run",
    "integration": "vitest run test/integration.test.ts",
    "migrate": "tsx src/scripts/migrate.ts",
    "seed": "tsx src/scripts/seed.ts",
    "test:integration": "vitest run test/integration.test.ts"
  },
  "dependencies": {
    "@in-midst-my-life/core": "workspace:*",
    "@in-midst-my-life/schema": "workspace:*",
    "exifr": "^7.1.3",
    "fastify": "^5.8.5",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.21.0",
    "sharp": "^0.34.5",
    "unzipper": "^0.12.3"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "@types/pg": "^8.20.0",
    "@types/unzipper": "^0.10.11",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  }
}
